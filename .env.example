# ── Web console ─────────────────────────────────────────────
# PORT is injected by Railway automatically; only set WEB_PORT for local override.
# Set BOTH of these to password-protect the console (recommended for Railway):
WEB_USER=
WEB_PASS=

# ── Business Central ────────────────────────────────────────
BC_TENANT_ID=
BC_CLIENT_ID=
BC_CLIENT_SECRET=
BC_ENVIRONMENT=PILOT
BC_COMPANY=Parsons-Kellogg

# ── Deposco ─────────────────────────────────────────────────
DEPOSCO_AUTH_URL=https://auth.deposco.com/oauth2/token
DEPOSCO_API_BASE=https://api.deposco.com/latest
DEPOSCO_CLIENT_ID=
DEPOSCO_CLIENT_SECRET=
DEPOSCO_REFRESH_TOKEN=
DEPOSCO_ENV=releasesupport
DEPOSCO_COMPANY=HIVE

# Note: the loop-mode gates (TO_PUSH_ENABLED etc.) are NOT needed here — a single-order
# --order run (what every button does) forces push + post on for that one order.
